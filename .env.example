# ============================================================================
# FBR Patrimoine — variables d'environnement
# ----------------------------------------------------------------------------
# Copier ce fichier en `.env.local` (déjà ignoré par git) et renseigner les
# valeurs. Sur Vercel, les déclarer dans Project Settings → Environment
# Variables (Production + Preview).
# ============================================================================

# --- Google Tag Manager ----------------------------------------------------
# Identifiant du conteneur GTM. Format : "GTM-XXXXXXX".
# Tant que cette variable est vide, AUCUN tag ne se charge et le site reste
# 100 % RGPD-safe. Le Consent Mode v2 est tout de même initialisé en mode
# "denied" par défaut côté client.
NEXT_PUBLIC_GTM_ID=

# ============================================================================
# Comptes Google à configurer côté client (voir GUIDE-TRACKING.md) :
#   1. Google Analytics 4 — créer une propriété → récupérer "G-XXXXXXXXXX"
#      → ajouter le tag GA4 dans GTM (Configuration Tag).
#   2. Google Ads — créer une action de conversion "Lead — Formulaire"
#      → récupérer l'ID de conversion "AW-XXXXXXXXX" + le libellé
#      → ajouter le tag "Suivi des conversions Google Ads" dans GTM,
#        déclenché sur l'événement dataLayer "generate_lead".
#   3. Google Search Console — propriété domaine www.fbr-patrimoine.com
#      → vérifier via le tag GTM (méthode "Google Tag Manager").
# ============================================================================

# --- Simulateur IA (Gemini 2.5 Flash Image) --------------------------------
# La génération d'image et le raffinage du prompt visiteur passent par
# Gemini. Sans GEMINI_API_KEY, le simulateur tourne en mode stub (renvoie
# la photo originale après un faux délai ~2 s — UX testable sans coût).
# Clé à créer sur https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Force le mode démo : ignore GEMINI_API_KEY et renvoie systématiquement
# l'image originale (pratique pour démos commerciales sans coût API).
SIMULATOR_DEMO=false

# Plafonds anti-abus (défauts si non définis : 3/jour/IP, 500/mois global).
SIMULATOR_DAILY_IP_CAP=3
SIMULATOR_MONTHLY_CAP=500

# --- Rate limit persistant (Upstash Redis) ---------------------------------
# Obligatoire en production sur Vercel (sinon les compteurs en mémoire se
# perdent au cold start serverless → quota mensuel jamais respecté).
# Compte gratuit sur https://console.upstash.com (10k cmds/jour offertes).
# Si les deux vars sont vides, fallback compteurs mémoire (dev / démo).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Ancienne intégration Replicate (DEPRECATED) ---------------------------
# Laissé pour mémoire — n'est plus lu par le code. À retirer si on confirme
# qu'on reste sur Gemini Image.
# REPLICATE_API_TOKEN=

# --- Emails via Resend -----------------------------------------------------
# Utilisé pour DEUX choses :
#   1. Le formulaire de contact (/contact + landings /devis-*)
#      → envoie un email à FBR + un accusé de réception au prospect.
#   2. Le simulateur IA (notification à FBR avec la photo téléversée).
#
# Sans ces variables :
#   - /api/contact répond 503 et le formulaire affiche une erreur
#     ("Service email temporairement indisponible, appelez-nous").
#   - Le simulateur tourne quand même mais ne notifie personne (log console).
#
# Setup :
#   1. Créer un compte sur https://resend.com (100 emails/jour offerts).
#   2. Vérifier le domaine fbr-patrimoine.com (ajouter SPF + DKIM + DMARC
#      dans le DNS du domaine).
#   3. Créer une clé API → la coller ici.
RESEND_API_KEY=

# Adresse destinataire des notifications (où FBR reçoit les leads).
# En production (domaine vérifié) : contact@fbr-patrimoine.com
FBR_NOTIFY_TO=contact@fbr-patrimoine.com

# Mode test Resend (expéditeur onboarding@resend.dev) : les emails ne
# peuvent être envoyés QU'À l'adresse du compte Resend. Mettre la même
# adresse que FBR_NOTIFY_TO ou laisser vide (déduit automatiquement).
RESEND_TEST_RECIPIENT=

# Expéditeur des emails sortants (notifications internes + accusés de
# réception aux prospects). Doit être une adresse sur un domaine vérifié
# dans Resend. Mettre entre guillemets si le libellé contient des espaces.
# Test : "FBR Patrimoine <onboarding@resend.dev>"
# Prod  : "FBR Patrimoine <noreply@fbr-patrimoine.com>"
FBR_NOTIFY_FROM=

# --- Gemini (Google AI) — alternative au simulateur Replicate --------------
# Clé API Gemini (https://aistudio.google.com/apikey). Utilisée pour les
# fonctions IA texte (analyse de la description du visiteur dans le
# simulateur, enrichissement du prompt avant la génération d'image).
GEMINI_API_KEY=
